# Copy this file to `.env` before running benchmark scripts.

# Baseline run configuration
OPENAI_MODEL=your_model_name
OPENAI_API_KEY=your_api_key
OPENAI_BASE_URL=https://your-openai-compatible-endpoint/v1

# Optional goal-judge configuration for evaluate_run.py
GOAL_JUDGE_MODEL=your_goal_judge_model
GOAL_JUDGE_API_KEY=your_goal_judge_api_key
GOAL_JUDGE_BASE_URL=https://your-openai-compatible-endpoint/v1
